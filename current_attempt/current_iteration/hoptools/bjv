#!/bin/bash
# Agent-facing verbs — thin mapper, NO Java knowledge. Maps from/to -> sealed image version and the
# verb -> the image's `jvmjob` action; the sealed single-JDK image does all the Java work.
#   bjv from build | bjv from test       (baseline under Java <from>)
#   bjv to   build | bjv to   test       (verify under Java <to>)
#   bjv to   run '<cmd>' | bjv from run '<cmd>'   (run an OpenRewrite recipe etc. in that env)
#   bjv scan                              (offline CWE scan in the <to> env)
set -uo pipefail
[ "${1:-}" = scan ] && exec jvm-run "${BJV_TO:?}" jvmjob scan
case "${1:-}" in
  from) V="${BJV_FROM:?}";;
  to)   V="${BJV_TO:?}";;
  *) echo "usage: bjv <from|to> <build|test|run [cmd]>  |  bjv scan" >&2; exit 2;;
esac
shift; ACT="${1:-}"; shift || true
case "$ACT" in
  build|test) exec jvm-run "$V" jvmjob "$ACT";;
  run)        exec jvm-run "$V" jvmjob run "$*";;
  *) echo "usage: bjv <from|to> <build|test|run [cmd]>  |  bjv scan" >&2; exit 2;;
esac
